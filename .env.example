UV_LINK_MODE=copy

# Optional if you prefer env auth over `just login-wandb`.
WANDB_API_KEY=
WANDB_PROJECT=stage2-sana-lora

# Use either HF_USERNAME or HF_ORG for pushed repo ids.
HF_USERNAME=your-hf-username
HF_ORG=

# Optional if you prefer env auth over `just login-hf`.
HF_TOKEN=

# Stage 2 SANA LoRA defaults.
SANA_MODEL_NAME=Efficient-Large-Model/Sana_1600M_1024px_BF16_diffusers
SANA_RESOLUTION=1024
SANA_MAX_TRAIN_STEPS=300
SANA_LORA_RANK=2
SANA_LORA_ALPHA=2
SANA_LEARNING_RATE=1e-4
SANA_GRADIENT_ACCUMULATION_STEPS=1
